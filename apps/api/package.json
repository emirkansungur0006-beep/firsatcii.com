{
  "name": "@firsatci/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "build": "npm run db:generate && nest build",
    "start": "node -e \"const { spawn } = require('child_process'); function run() { console.log('Basiyoruz...'); const p = spawn('node', ['dist/apps/api/src/main.js'], { stdio: 'inherit' }); p.on('exit', code => { if(code !== 0) { console.log('Veritabani uykuda (P1017). 15 saniye bekleyip tekrar denenecek...'); setTimeout(run, 15000); } }); } run();\"",
    "lint": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "ts-node --project tsconfig.json prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@firsatci/shared": "*",
    "@nestjs/cli": "^10.4.9",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/platform-socket.io": "^10.4.15",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/throttler": "^6.2.1",
    "@nestjs/websockets": "^10.4.15",
    "@prisma/client": "^5.22.0",
    "@types/cron": "^2.0.1",
    "@types/nodemailer": "^8.0.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "cron": "^3.5.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "nodemailer": "^8.0.7",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prisma": "^5.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@nestjs/schematics": "^10.2.3",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^10.0.0"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
